{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022-debug",
      "displayName": "Windows VS2022 Debug",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/vs2022-debug",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/vs2022-debug",
        "DECLSOUND_BUILD_CLI": "ON"
      }
    },
    {
      "name": "windows-vs2022-release",
      "displayName": "Windows VS2022 Release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/vs2022-release",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/vs2022-release",
        "DECLSOUND_BUILD_CLI": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-debug",
      "displayName": "Build Windows Debug",
      "configurePreset": "windows-vs2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-release",
      "displayName": "Build Windows Release",
      "configurePreset": "windows-vs2022-release",
      "configuration": "Release"
    }
  ]
}
